    "version": "0.2.0",
    "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Server",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/server/index.ts",
      "outFiles": ["${workspaceFolder}/**/*.js"],
      "env": {
        "NODE_ENV": "development",
        "DATABASE_URL": "postgres://postgres:postgres@localhost:32768/rest_express",
        "JWT_SECRET": "your-secret-key"
      }
    }
  ]
}